# Stallwache Configuration File
# Kopiere diese Datei zu .env und setze deine eigenen Werte

# =======================
# CAMERA CONFIGURATION
# =======================
CAMERA_RTSP_URL=rtsp://192.168.178.108:554/stream
CAMERA_USERNAME=Stallwache123!
CAMERA_PASSWORD=Stallwache123!
FRAME_SKIP=1
RESIZE_WIDTH=1280
RESIZE_HEIGHT=720

# =======================
# AI MODEL CONFIGURATION
# =======================
YOLO_MODEL_PATH=./models/yolov8m.pt
CONFIDENCE_THRESHOLD=0.65
IOU_THRESHOLD=0.45

# =======================
# TELEGRAM CONFIGURATION
# =======================
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_SEND_IMAGE=true
TELEGRAM_ALERT_COOLDOWN=60

# =======================
# DATABASE CONFIGURATION
# =======================
ENABLE_DATABASE=true
DATABASE_PATH=./data/stallwache.db
LOG_RETENTION_DAYS=30

# =======================
# LOGGING CONFIGURATION
# =======================
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# =======================
# SYSTEM CONFIGURATION
# =======================
DEBUG_MODE=false
DEVICE=cpu
NUM_WORKERS=4
STREAM_TIMEOUT=30
INFERENCE_TIMEOUT=5

# =======================
# FEATURE FLAGS
# =======================
FEATURE_MULTI_CAMERA=false
FEATURE_CLOUD_BACKUP=false
FEATURE_WEB_DASHBOARD=false
